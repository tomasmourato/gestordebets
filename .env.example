# String de ligação ao PostgreSQL:
# postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Fornecedores geridos (Supabase, Neon, Railway, Vercel Postgres) dão a
# connection string já com ?sslmode=require.
DATABASE_URL=postgres://user:password@host:5432/bettrackr

# Segredo usado para assinar os JWT. Gera um valor aleatório forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Chave da API do Gemini, usada na importação de boletins por screenshot.
GEMINI_API_KEY=
