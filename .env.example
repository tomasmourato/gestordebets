# String de ligação ao PostgreSQL:
# postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Fornecedores geridos (Supabase, Neon, Railway, Vercel Postgres) dão a
# connection string já com ?sslmode=require.
DATABASE_URL=postgres://user:password@host:5432/bettrackr

# Segredo usado para assinar os JWT. Gera um valor aleatório forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Chave da API do Gemini, usada na importação de boletins por screenshot.
GEMINI_API_KEY=

# --- Recuperação de password (opcional) ---
# Chave da API do Resend (resend.com) para enviar os emails de reset.
# Sem ela, o link de recuperação aparece apenas no log do servidor (dev).
RESEND_API_KEY=

# Remetente dos emails. Sem domínio verificado no Resend, deixa vazio para
# usar o sandbox "BetTrackr <onboarding@resend.dev>" (só entrega ao email
# da conta Resend). Com domínio: "BetTrackr <noreply@teudominio.pt>".
MAIL_FROM=

# Base dos links nos emails (sem barra final). Default: produção na Vercel,
# http://localhost:3000 em desenvolvimento.
APP_BASE_URL=
