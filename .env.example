# Já existente no teu projeto
GEMINI_API_KEY=

# --- NOVO ---
# String de ligação ao PostgreSQL. Formato:
# postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Se usares Neon, Supabase, Railway ou Vercel Postgres, copia a
# "connection string" que eles te dão (normalmente já inclui ?sslmode=require)
DATABASE_URL=postgres://user:password@host:5432/gestordebets

# Segredo usado para assinar os JWT. Gera um valor aleatório forte, por exemplo:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
