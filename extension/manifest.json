{
  "manifest_version": 3,
  "name": "BetTrackr — Importar apostas",
  "version": "1.0.3",
  "description": "Importa as tuas apostas do Betclic.pt e Betano.pt diretamente para o BetTrackr.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.betclic.pt/*",
    "https://www.betano.pt/*",
    "https://betano.pt/*",
    "https://*.begmedia.pt/*",
    "https://*.begmedia.com/*",
    "https://gestordebets.vercel.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Importar apostas"
  },
  "content_scripts": [
    {
      "matches": ["https://www.betclic.pt/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.betclic.pt/*"],
      "js": ["src/content-betclic.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.betano.pt/*", "https://betano.pt/*"],
      "js": ["src/inject-betano.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://www.betano.pt/*", "https://betano.pt/*"],
      "js": ["src/content-betano.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://gestordebets.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/content-bettrackr.js"],
      "run_at": "document_idle"
    }
  ]
}
